cam = ml.get_camera("Tennis Court (NE)")

roof_z = 20.0
plane = ((0, 0, roof_z), (0, 0, 1))

for name, px, py in [
    ("Building (NW)", 1460, 274),
    ("Building (NE)", 1486, 274),
]:
    direction = cam.get_pixel_direction((px, py))
    point = ml.intersect_ray_and_plane((cam.xyz, direction), plane)
    print(f'md.landmarks["{name}"] = ({point[0]:.3f}, {point[1]:.3f}, {point[2]:.3f})')

